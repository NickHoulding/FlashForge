# =============================================================================
# FlashForge MCP Server - Environment Configuration Template
# =============================================================================
# Copy this file to .env and customize the values for your environment.
# All settings have sensible defaults if not specified.

# =============================================================================
# Ollama Connection
# =============================================================================

# Model name to use for flashcard generation
# Examples: qwen3.5:4b, llama3.2:1b, mistral:7b
FLASHCARD_MODEL="llama3.1:8b"

# Enable extended reasoning mode during generation (true/false)
# Set to "true" to enable more detailed thought processes
SHOULD_THINK=false

# Maximum seconds to wait for Ollama API responses
# Increase for larger models or slower systems
OLLAMA_TIMEOUT=300

# =============================================================================
# VectorForge RAG Connection
# =============================================================================

# Base URL for the VectorForge RAG service
# Update if running VectorForge on a different host/port
VECTORFORGE_BASE_URL="http://localhost:3001"

# Number of top results to retrieve from VectorForge search
# Range: 1-50, higher values provide more context but slower processing
RAG_TOP_K=5

# Maximum character length for concatenated RAG context
# Range: 1-50000, adjust based on your model's context window
CONTEXT_MAX_LEN=10000

# Maximum seconds to wait for HTTP requests to external services
HTTP_TIMEOUT=30

# =============================================================================
# Flashcard Constraints
# =============================================================================

# Maximum character length for flashcard questions
# Range: 1-1000, keep questions concise for better learning
QUESTION_MAX_LEN=200

# Maximum character length for flashcard answers
# Range: 1-2000, allows for detailed explanations
ANSWER_MAX_LEN=500

# Maximum number of flashcards that can be generated in one request
# Range: 1-100, controls batch generation size
MAX_CARDS=50

# Maximum character length for input text source material
# Range: 1-100000, larger values allow processing longer documents
TEXT_MAX_LEN=5000

# =============================================================================
# File Storage
# =============================================================================

# Directory path for saving flashcard output files
# Can be relative (./output) or absolute (/var/flashforge/output)
# Note: Directory must exist before starting the server
OUTPUT_DIR="./.output"

# Maximum character length for output file names
# Keep under filesystem limits (typically 255)
MAX_FILE_NAME_LEN=255

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging verbosity level for the MCP server process
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for development, INFO or WARNING for production
FF_LOG_LEVEL=INFO

# Path to log file for rotating file handler
# Can be relative (.logs/flashforge.log) or absolute
FF_LOG_FILE=".logs/flashforge.log"

# Enable JSON logging to console (true/false)
# Useful for production environments with log aggregation
FF_LOG_JSON_CONSOLE=false

# Maximum character length for text sanitization in logs
# Prevents sensitive data exposure and log bloat
FF_LOG_MAX_TEXT_LEN=100

# Maximum size per log file before rotation in bytes
# Default: 10485760 (10MB), minimum: 1024 (1KB)
FF_LOG_MAX_BYTES=10485760

# Number of backup log files to keep during rotation
# Range: 0-100, total log space = MAX_BYTES * (BACKUP_COUNT + 1)
FF_LOG_BACKUP_COUNT=5
